# Copia este archivo a `.env.local` y rellena valores.
# Docs: mismo patrón BFF Cody (login → chat-session → thread → streaming).

# --- Obligatorio: URL de la Cody API **sin barra final** ---
# Opción A: nombre explícito (prioritario si existe junto con CODY_API_BASE_URL)
CODY_INTERNAL_API_URL=https://cody-public-api-XXXX.us-central1.run.app

# Opción B: reutiliza la misma base que otros integraciones legacy
CODY_API_BASE_URL=https://cody-public-api-XXXX.us-central1.run.app

# --- Bootstrap del widget (servidor): usuario de servicio + agente ---
CODY_AGENT_ID=
CODY_SERVICE_USERNAME=demo.prisa
# o
# CODY_SERVICE_EMAIL=
#
# Equivalente si no defines CODY_SERVICE_* :
# CODY_CHAT_USERNAME=demo.prisa
# CODY_CHAT_PASSWORD=…

CODY_SERVICE_PASSWORD=

# URLs de fichas técnicas (contexto obligatorio recomendado)
CODY_TECHNICAL_SHEETS_URLS=https://prisa.mx/wp-content/uploads/2025/06/Fichas_impermeabilizantes.pdf

# Opcional
# CODY_TENANT_ID=
# NEXT_PUBLIC_SITE_URL=https://tu-sitio.com

# --- Copia del widget (CLIENTE): deben llevar NEXT_PUBLIC_* y reiniciar dev / rebuild ---
# NEXT_PUBLIC_ASSISTANT_CHANNEL_LABEL=Canal de ayuda
# NEXT_PUBLIC_ASSISTANT_TITLE=Asesor PRISA
# NEXT_PUBLIC_ASSISTANT_SUBTITLE=Te ayudamos…
# Primer mensaje en el chat (alternativa legada: NEXT_PUBLIC_ASSISTANT_INITIAL_MESSAGE):
# NEXT_PUBLIC_ASSISTANT_WELCOME_MESSAGE=Hola, soy…
# Burbuja previa al abrir:
# NEXT_PUBLIC_ASSISTANT_WELCOME_BUBBLE=¿En qué te ayudo?
# NEXT_PUBLIC_ASSISTANT_BUBBLE_OPEN_HINT=Pulsa para abrir
# Panel minimizado / input / secciones:
# NEXT_PUBLIC_ASSISTANT_MINIMIZED_HINT=Retomar chat
# NEXT_PUBLIC_ASSISTANT_MINIMIZED_OPEN_BUTTON=Abrir
# NEXT_PUBLIC_ASSISTANT_QUICK_SECTION_LABEL=Opciones rápidas
# NEXT_PUBLIC_ASSISTANT_MESSAGES_SECTION_LABEL=Conversación
# NEXT_PUBLIC_ASSISTANT_INPUT_PLACEHOLDER=Escribe…
# NEXT_PUBLIC_ASSISTANT_INPUT_SR_LABEL=Escribe tu mensaje
# Acciones rápidas (solo las que necesites): surface | quote | store | promos | support
# NEXT_PUBLIC_ASSISTANT_QUICK_SURFACE=…
# NEXT_PUBLIC_ASSISTANT_QUICK_QUOTE=…
# NEXT_PUBLIC_ASSISTANT_QUICK_STORE=…

# Crear thread: por defecto título/resumen texto (como Swagger). Para enviar JSON null usa:
# CODY_THREAD_BODY_NULL_JSON=true

# Código de referencia Cody (solo servidor; no subas valores reales a git).
